generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model CarbonProject {
  id                  String   @id @default(cuid())
  projectId           String   @unique
  name                String
  methodology         String
  country             String
  projectType         String
  status              String   @default("Pending")
  vintageYear         Int
  totalCreditsIssued  Int      @default(0)
  totalCreditsRetired Int      @default(0)
  metadataCid         String
  verifierAddress     String
  ownerAddress        String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  batches     CreditBatch[]
  retirements RetirementRecord[]
  listings    MarketListing[]
  monitoring  MonitoringData[]
}

model CreditBatch {
  id          String   @id @default(cuid())
  batchId     String   @unique
  projectId   String
  vintageYear Int
  amount      Int
  serialStart String
  serialEnd   String
  status      String   @default("Active")
  metadataCid String
  issuedAt    DateTime @default(now())

  project     CarbonProject      @relation(fields: [projectId], references: [projectId])
  retirements RetirementRecord[]
  listings    MarketListing[]
}

model RetirementRecord {
  id               String   @id @default(cuid())
  retirementId     String   @unique
  batchId          String
  projectId        String
  amount           Int
  retiredBy        String
  beneficiary      String
  retirementReason String
  vintageYear      Int
  serialNumbers    String[]
  txHash           String
  retiredAt        DateTime @default(now())

  batch   CreditBatch   @relation(fields: [batchId], references: [batchId])
  project CarbonProject @relation(fields: [projectId], references: [projectId])
}

model MarketListing {
  id              String   @id @default(cuid())
  listingId       String   @unique
  projectId       String
  batchId         String
  seller          String
  amountAvailable Int
  pricePerCredit  String
  vintageYear     Int
  methodology     String
  country         String
  status          String   @default("Active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project CarbonProject @relation(fields: [projectId], references: [projectId])
  batch   CreditBatch   @relation(fields: [batchId], references: [batchId])
}

model MonitoringData {
  id               String   @id @default(cuid())
  projectId        String
  period           String
  tonnesVerified   Int
  methodologyScore Int
  satelliteCid     String
  submittedBy      String
  submittedAt      DateTime @default(now())

  project CarbonProject @relation(fields: [projectId], references: [projectId])

  @@unique([projectId, period])
}

model User {
  id        String   @id @default(cuid())
  publicKey String   @unique
  role      String   @default("corporation")
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Referral system
// ---------------------------------------------------------------------------

/// One record per platform contributor (extends User with bounty-platform data).
model Contributor {
  id            String   @id @default(cuid())
  /// Foreign key to User.id (1-to-1)
  userId        String   @unique
  /// Unique referral code used in invite links (?ref=<code>)
  referralCode  String   @unique
  /// ID of the Contributor who referred this person (null = organic sign-up)
  referredById  String?
  /// Total bounties completed on the platform
  bountiesCompleted Int  @default(0)
  /// Total bonus USD earned through the referral programme
  totalBonusEarned  Float @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  referredBy    Contributor?  @relation("ReferralTree", fields: [referredById], references: [id])
  referrals     Contributor[] @relation("ReferralTree")

  referralBonuses ReferralBonus[]
  milestones      ReferralMilestone[]

  @@index([referredById])
  @@index([referralCode])
}

/// Tracks each bonus payout: 5 % of referred contributor's first 3 bounties.
model ReferralBonus {
  id              String   @id @default(cuid())
  /// Referrer (the person earning the bonus)
  referrerId      String
  /// The contributor whose bounty triggered the bonus
  referredId      String
  /// ID of the bounty that was completed
  bountyId        String
  /// USD value of the bounty that was completed
  bountyAmountUsd Float
  /// Bonus amount (5 % of bountyAmountUsd, max $500 total per referrer)
  bonusAmountUsd  Float
  /// Which bounty number this is for the referred contributor (1, 2, or 3)
  bountyNumber    Int
  status          ReferralBonusStatus @default(PENDING)
  createdAt       DateTime @default(now())
  paidAt          DateTime?

  referrer        Contributor @relation(fields: [referrerId], references: [id])

  @@unique([referredId, bountyNumber])
  @@index([referrerId])
  @@index([status])
}

enum ReferralBonusStatus {
  PENDING
  PAID
  CANCELLED
}

/// Growth-campaign milestones: bonuses for hitting 5 / 10 / 20 referrals.
model ReferralMilestone {
  id            String   @id @default(cuid())
  contributorId String
  /// 5, 10, or 20
  milestone     Int
  bonusAmountUsd Float
  status        MilestoneStatus @default(PENDING)
  achievedAt    DateTime @default(now())
  paidAt        DateTime?

  contributor   Contributor @relation(fields: [contributorId], references: [id])

  @@unique([contributorId, milestone])
  @@index([contributorId])
  @@index([status])
}

enum MilestoneStatus {
  PENDING
  PAID
}

model SupportTicket {
  id              String   @id @default(cuid())
  ticketId        String   @unique
  bountyId        String
  contributorId   String
  maintainerId    String?
  type            String   // unclear-requirement, blocker-bug, scope-creep, access-issue
  status          String   @default("open") // open, in-progress, resolved
  title           String
  description     String
  attachments     String[]
  createdAt       DateTime @default(now())
  acknowledgedAt  DateTime?
  resolvedAt      DateTime?
  resolution      String?

  @@index([bountyId])
  @@index([contributorId])
  @@index([status])
  @@index([createdAt])
}

model SupportMetrics {
  id            String   @id @default(cuid())
  ticketType    String   // ticket type
  frequency     Int      @default(0) // number of times this issue type appears
  avgResolution Int      @default(0) // average resolution time in hours
  lastUpdated   DateTime @default(now()) @updatedAt

  @@unique([ticketType])
}

// ── Onboarding & Certification System ─────────────────────────────────────

/// Tracks a contributor's overall onboarding state and step completions.
model OnboardingProgress {
  id            String    @id @default(cuid())
  contributorId String    @unique
  // not_started | in_progress | completed
  status        String    @default("not_started")
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  steps         OnboardingStep[]

  @@index([contributorId])
  @@index([status])
}

/// One of the 5 intro onboarding tasks for a contributor.
model OnboardingStep {
  id            String    @id @default(cuid())
  progressId    String
  stepKey       String
  // setup | first_pr | testing | documentation | code_review
  title         String
  description   String
  // not_started | in_progress | completed
  status        String    @default("not_started")
  completedAt   DateTime?
  durationMs    Int?      // milliseconds from step start to completion

  progress      OnboardingProgress @relation(fields: [progressId], references: [id])

  @@unique([progressId, stepKey])
  @@index([progressId])
}

/// A skill assessment challenge for a given domain.
model SkillAssessment {
  id          String   @id @default(cuid())
  assessmentId String  @unique
  domain      String
  // smart_contracts | frontend | backend
  title       String
  description String
  // description of what is tested — actual quiz content is external
  maxScore    Int      @default(100)
  passingScore Int     @default(80)
  createdAt   DateTime @default(now())

  attempts    AssessmentAttempt[]

  @@index([domain])
}

/// A contributor's attempt at a skill assessment.
model AssessmentAttempt {
  id            String   @id @default(cuid())
  attemptId     String   @unique
  assessmentId  String
  contributorId String
  score         Int      // 0-100, submitted by the quiz engine
  passed        Boolean
  startedAt     DateTime
  completedAt   DateTime @default(now())

  assessment    SkillAssessment @relation(fields: [assessmentId], references: [assessmentId])

  @@index([assessmentId])
  @@index([contributorId])
}

/// A certification awarded to a contributor for a given domain.
/// Valid for 1 year from issuedAt.
model Certification {
  id              String   @id @default(cuid())
  certificationId String   @unique
  contributorId   String
  domain          String
  // smart_contracts | frontend | backend | general
  issuedAt        DateTime @default(now())
  expiresAt       DateTime
  // issuedAt + 1 year
  revokedAt       DateTime?
  highestScore    Int      // best passing score that triggered certification

  @@unique([contributorId, domain])
  @@index([contributorId])
  @@index([expiresAt])
}

/// A badge awarded to a contributor for reaching a milestone.
model ContributorBadge {
  id            String   @id @default(cuid())
  badgeId       String   @unique
  contributorId String
  badge         String
  // first_contribution | first_certification | mentor_others
  awardedAt     DateTime @default(now())
  metadata      String?  // JSON: extra context (e.g. which bounty, which certification)

  @@unique([contributorId, badge])
  @@index([contributorId])
}

// ── Bounty Dependency System ──────────────────────────────────────────────

model Bounty {
  id                  String   @id @default(cuid())
  title               String
  description         String
  requirements        String   // JSON string of array
  acceptanceCriteria  String   // JSON string of array
  rewardUsd           Float
  difficulty          String   // beginner, intermediate, advanced, expert
  deadline            DateTime
  bountyType          String
  status              String   @default("open") // open, in_progress, closed, cancelled
  reviewerAddress     String
  reviewerGithub      String?
  tags                String   // JSON string of array
  isInternal          Boolean  @default(false)
  featured            Boolean  @default(false)
  applicationCount    Int      @default(0)
  priceOverride       Float?
  budgetProjectId     String?  // Budget tracking
  budgetPeriod        String?  // Budget period
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Dependency relationships
  prerequisites       BountyDependency[] @relation("BountyPrerequisites")
  dependents          BountyDependency[] @relation("BountyDependents")

  @@index([status])
  @@index([featured])
  @@index([deadline])
  @@index([bountyType])
}

model BountyDependency {
  id                   String   @id @default(cuid())
  prerequisiteBountyId String   // The bounty that must be completed first
  dependentBountyId    String   // The bounty that depends on the prerequisite
  isRequired           Boolean  @default(true) // True for hard dependencies, false for soft recommendations
  createdAt            DateTime @default(now())

  prerequisiteBounty   Bounty @relation("BountyPrerequisites", fields: [prerequisiteBountyId], references: [id], onDelete: Cascade)
  dependentBounty      Bounty @relation("BountyDependents", fields: [dependentBountyId], references: [id], onDelete: Cascade)

  @@unique([prerequisiteBountyId, dependentBountyId])
  @@index([prerequisiteBountyId])
  @@index([dependentBountyId])
}
