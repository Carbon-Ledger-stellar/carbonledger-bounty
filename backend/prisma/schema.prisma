generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CarbonProject {
  id                  String   @id @default(cuid())
  projectId           String   @unique
  name                String
  methodology         String
  country             String
  projectType         String
  status              String   @default("Pending")
  vintageYear         Int
  totalCreditsIssued  Int      @default(0)
  totalCreditsRetired Int      @default(0)
  metadataCid         String
  verifierAddress     String
  ownerAddress        String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  batches     CreditBatch[]
  retirements RetirementRecord[]
  listings    MarketListing[]
  monitoring  MonitoringData[]
}

model CreditBatch {
  id          String   @id @default(cuid())
  batchId     String   @unique
  projectId   String
  vintageYear Int
  amount      Int
  serialStart String
  serialEnd   String
  status      String   @default("Active")
  metadataCid String
  issuedAt    DateTime @default(now())

  project     CarbonProject      @relation(fields: [projectId], references: [projectId])
  retirements RetirementRecord[]
  listings    MarketListing[]
}

model RetirementRecord {
  id               String   @id @default(cuid())
  retirementId     String   @unique
  batchId          String
  projectId        String
  amount           Int
  retiredBy        String
  beneficiary      String
  retirementReason String
  vintageYear      Int
  serialNumbers    String[]
  txHash           String
  retiredAt        DateTime @default(now())

  batch   CreditBatch   @relation(fields: [batchId], references: [batchId])
  project CarbonProject @relation(fields: [projectId], references: [projectId])
}

model MarketListing {
  id              String   @id @default(cuid())
  listingId       String   @unique
  projectId       String
  batchId         String
  seller          String
  amountAvailable Int
  pricePerCredit  String
  vintageYear     Int
  methodology     String
  country         String
  status          String   @default("Active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project CarbonProject @relation(fields: [projectId], references: [projectId])
  batch   CreditBatch   @relation(fields: [batchId], references: [batchId])
}

model MonitoringData {
  id               String   @id @default(cuid())
  projectId        String
  period           String
  tonnesVerified   Int
  methodologyScore Int
  satelliteCid     String
  submittedBy      String
  submittedAt      DateTime @default(now())

  project CarbonProject @relation(fields: [projectId], references: [projectId])

  @@unique([projectId, period])
}

model User {
  id        String   @id @default(cuid())
  publicKey String   @unique
  role      String   @default("corporation")
  createdAt DateTime @default(now())
}

model SupportTicket {
  id              String   @id @default(cuid())
  ticketId        String   @unique
  bountyId        String
  contributorId   String
  maintainerId    String?
  type            String   // unclear-requirement, blocker-bug, scope-creep, access-issue
  status          String   @default("open") // open, in-progress, resolved
  title           String
  description     String
  attachments     String[]
  createdAt       DateTime @default(now())
  acknowledgedAt  DateTime?
  resolvedAt      DateTime?
  resolution      String?

  @@index([bountyId])
  @@index([contributorId])
  @@index([status])
  @@index([createdAt])
}

model SupportMetrics {
  id            String   @id @default(cuid())
  ticketType    String   // ticket type
  frequency     Int      @default(0) // number of times this issue type appears
  avgResolution Int      @default(0) // average resolution time in hours
  lastUpdated   DateTime @default(now()) @updatedAt

  @@unique([ticketType])
}

// ── Dispute Resolution System ──────────────────────────────────────────────

/// A dispute raised when a contributor claims work is complete but the
/// reviewer rejects it.  Lifecycle: opened → under_review → decided →
/// [appealed → final].
model Dispute {
  id              String    @id @default(cuid())
  disputeId       String    @unique
  bountyId        String
  contributorId   String    // the party claiming work is complete
  reviewerId      String    // the party who rejected the submission
  arbitratorId    String?   // pre-assigned arbitrator (out-of-scope to assign here)
  status          String    @default("opened")
  // opened | under_review | decided | appealed | final

  // Review window
  reviewDeadline  DateTime  // default: createdAt + 7 days
  reviewExtended  Boolean   @default(false)

  // Appeal tracking
  appealCount     Int       @default(0)  // max 1
  appealedAt      DateTime?
  appealReason    String?

  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  decidedAt       DateTime?
  finalizedAt     DateTime?

  // Relations
  evidence        Evidence[]
  decisions       DisputeDecision[]
  auditLogs       DisputeAuditLog[]

  @@index([bountyId])
  @@index([contributorId])
  @@index([arbitratorId])
  @@index([status])
}

/// Evidence submitted during a dispute: PR links, test results, docs, comments.
model Evidence {
  id          String   @id @default(cuid())
  evidenceId  String   @unique
  disputeId   String
  submittedBy String
  type        String
  // pr_link | test_result | documentation | comment | other
  title       String
  content     String   // URL or text body
  metadata    String?  // JSON blob for extra fields (e.g. PR number, test suite)
  isAppeal    Boolean  @default(false)  // true = submitted as part of the appeal
  createdAt   DateTime @default(now())

  dispute     Dispute  @relation(fields: [disputeId], references: [disputeId])

  @@index([disputeId])
  @@index([submittedBy])
}

/// A binding decision made by the arbitrator (or on appeal).
model DisputeDecision {
  id          String   @id @default(cuid())
  decisionId  String   @unique
  disputeId   String
  arbitratorId String
  decision    String
  // approved | rejected | partial
  rationale   String
  paymentBps  Int      @default(0)
  // basis points of bounty reward: 10000=full, 5000=half, 0=none
  isAppeal    Boolean  @default(false)
  createdAt   DateTime @default(now())

  dispute     Dispute  @relation(fields: [disputeId], references: [disputeId])

  @@index([disputeId])
}

/// Immutable audit trail: every state transition and action is logged here.
model DisputeAuditLog {
  id          String   @id @default(cuid())
  logId       String   @unique
  disputeId   String
  actorId     String
  action      String   // e.g. DISPUTE_OPENED, EVIDENCE_SUBMITTED, DECISION_MADE, …
  payload     String?  // JSON snapshot of relevant data at the time
  createdAt   DateTime @default(now())

  dispute     Dispute  @relation(fields: [disputeId], references: [disputeId])

  @@index([disputeId])
  @@index([createdAt])
}
