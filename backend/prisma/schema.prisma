generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CarbonProject {
  id                  String   @id @default(cuid())
  projectId           String   @unique
  name                String
  methodology         String
  country             String
  projectType         String
  status              String   @default("Pending")
  vintageYear         Int
  totalCreditsIssued  Int      @default(0)
  totalCreditsRetired Int      @default(0)
  metadataCid         String
  verifierAddress     String
  ownerAddress        String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  batches     CreditBatch[]
  retirements RetirementRecord[]
  listings    MarketListing[]
  monitoring  MonitoringData[]
}

model CreditBatch {
  id          String   @id @default(cuid())
  batchId     String   @unique
  projectId   String
  vintageYear Int
  amount      Int
  serialStart String
  serialEnd   String
  status      String   @default("Active")
  metadataCid String
  issuedAt    DateTime @default(now())

  project     CarbonProject      @relation(fields: [projectId], references: [projectId])
  retirements RetirementRecord[]
  listings    MarketListing[]
}

model RetirementRecord {
  id               String   @id @default(cuid())
  retirementId     String   @unique
  batchId          String
  projectId        String
  amount           Int
  retiredBy        String
  beneficiary      String
  retirementReason String
  vintageYear      Int
  serialNumbers    String[]
  txHash           String
  retiredAt        DateTime @default(now())

  batch   CreditBatch   @relation(fields: [batchId], references: [batchId])
  project CarbonProject @relation(fields: [projectId], references: [projectId])
}

model MarketListing {
  id              String   @id @default(cuid())
  listingId       String   @unique
  projectId       String
  batchId         String
  seller          String
  amountAvailable Int
  pricePerCredit  String
  vintageYear     Int
  methodology     String
  country         String
  status          String   @default("Active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project CarbonProject @relation(fields: [projectId], references: [projectId])
  batch   CreditBatch   @relation(fields: [batchId], references: [batchId])
}

model MonitoringData {
  id               String   @id @default(cuid())
  projectId        String
  period           String
  tonnesVerified   Int
  methodologyScore Int
  satelliteCid     String
  submittedBy      String
  submittedAt      DateTime @default(now())

  project CarbonProject @relation(fields: [projectId], references: [projectId])

  @@unique([projectId, period])
}

model User {
  id        String   @id @default(cuid())
  publicKey String   @unique
  role      String   @default("corporation")
  createdAt DateTime @default(now())
}

model SupportTicket {
  id              String   @id @default(cuid())
  ticketId        String   @unique
  bountyId        String
  contributorId   String
  maintainerId    String?
  type            String   // unclear-requirement, blocker-bug, scope-creep, access-issue
  status          String   @default("open") // open, in-progress, resolved
  title           String
  description     String
  attachments     String[]
  createdAt       DateTime @default(now())
  acknowledgedAt  DateTime?
  resolvedAt      DateTime?
  resolution      String?

  @@index([bountyId])
  @@index([contributorId])
  @@index([status])
  @@index([createdAt])
}

model SupportMetrics {
  id            String   @id @default(cuid())
  ticketType    String   // ticket type
  frequency     Int      @default(0) // number of times this issue type appears
  avgResolution Int      @default(0) // average resolution time in hours
  lastUpdated   DateTime @default(now()) @updatedAt

  @@unique([ticketType])
}

// ── Reputation System ─────────────────────────────────────────────────────────

/// Tracks a contributor's multi-dimensional reputation on the platform.
model Contributor {
  id              String   @id @default(cuid())
  /// Stellar public key / wallet address uniquely identifies the contributor.
  walletAddress   String   @unique
  displayName     String?

  // ── Aggregate reputation score (0–100) ──────────────────────────────────
  reputationScore Float    @default(50)

  // ── Weighted dimension scores (0–100 each) ──────────────────────────────
  /// Code quality: reviewer-assigned 5-point scale, weighted 40%.
  codeQualityScore    Float @default(50)
  /// Timeliness: 100% on-time, 50% if 1 week late, 0% if >2 weeks late. Weight 30%.
  timelinessScore     Float @default(50)
  /// Communication: responsiveness to review comments. Weight 20%.
  communicationScore  Float @default(50)
  /// Peer feedback: community ratings. Weight 10%.
  peerFeedbackScore   Float @default(50)

  // ── Counters for trend analysis ─────────────────────────────────────────
  totalBountiesCompleted  Int @default(0)
  totalBountiesOnTime     Int @default(0)
  totalBountiesLate       Int @default(0)
  totalBountiesVeryLate   Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  history ReputationHistory[]

  @@index([reputationScore])
  @@index([walletAddress])
}

/// Immutable log of every reputation update — enables trend detection and audit.
model ReputationHistory {
  id            String   @id @default(cuid())
  contributorId String

  /// Snapshot of the overall score immediately after this update.
  scoreBefore   Float
  scoreAfter    Float

  // ── Dimension snapshots at the time of this event ───────────────────────
  codeQualityBefore   Float
  codeQualityAfter    Float
  timelinessBefore    Float
  timelinessAfter     Float
  communicationBefore Float
  communicationAfter  Float
  peerFeedbackBefore  Float
  peerFeedbackAfter   Float

  // ── Input signals that triggered this update ────────────────────────────
  bountyId            String?
  /// Reviewer-assigned score on a 1–5 scale.
  reviewerScore       Float?
  /// Actual submission date for timeliness calculation.
  submittedAt         DateTime?
  /// Original deadline for timeliness calculation.
  deadlineAt          DateTime?
  /// Average latency (hours) between review comments posted and contributor replies.
  avgResponseHours    Float?
  /// Peer/community rating on a 1–5 scale.
  peerRating          Float?

  /// Human-readable summary of what changed.
  changeReason        String?

  createdAt DateTime @default(now())

  contributor Contributor @relation(fields: [contributorId], references: [id])

  @@index([contributorId])
  @@index([createdAt])
  @@index([bountyId])
}
