generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CarbonProject {
  id                  String   @id @default(cuid())
  projectId           String   @unique
  name                String
  methodology         String
  country             String
  projectType         String
  status              String   @default("Pending")
  vintageYear         Int
  totalCreditsIssued  Int      @default(0)
  totalCreditsRetired Int      @default(0)
  metadataCid         String
  verifierAddress     String
  ownerAddress        String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  batches     CreditBatch[]
  retirements RetirementRecord[]
  listings    MarketListing[]
  monitoring  MonitoringData[]
}

model CreditBatch {
  id          String   @id @default(cuid())
  batchId     String   @unique
  projectId   String
  vintageYear Int
  amount      Int
  serialStart String
  serialEnd   String
  status      String   @default("Active")
  metadataCid String
  issuedAt    DateTime @default(now())

  project     CarbonProject      @relation(fields: [projectId], references: [projectId])
  retirements RetirementRecord[]
  listings    MarketListing[]
}

model RetirementRecord {
  id               String   @id @default(cuid())
  retirementId     String   @unique
  batchId          String
  projectId        String
  amount           Int
  retiredBy        String
  beneficiary      String
  retirementReason String
  vintageYear      Int
  serialNumbers    String[]
  txHash           String
  retiredAt        DateTime @default(now())

  batch   CreditBatch   @relation(fields: [batchId], references: [batchId])
  project CarbonProject @relation(fields: [projectId], references: [projectId])
}

model MarketListing {
  id              String   @id @default(cuid())
  listingId       String   @unique
  projectId       String
  batchId         String
  seller          String
  amountAvailable Int
  pricePerCredit  String
  vintageYear     Int
  methodology     String
  country         String
  status          String   @default("Active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project CarbonProject @relation(fields: [projectId], references: [projectId])
  batch   CreditBatch   @relation(fields: [batchId], references: [batchId])
}

model MonitoringData {
  id               String   @id @default(cuid())
  projectId        String
  period           String
  tonnesVerified   Int
  methodologyScore Int
  satelliteCid     String
  submittedBy      String
  submittedAt      DateTime @default(now())

  project CarbonProject @relation(fields: [projectId], references: [projectId])

  @@unique([projectId, period])
}

model User {
  id        String   @id @default(cuid())
  publicKey String   @unique
  role      String   @default("corporation")
  createdAt DateTime @default(now())
}

model SupportTicket {
  id              String   @id @default(cuid())
  ticketId        String   @unique
  bountyId        String
  contributorId   String
  maintainerId    String?
  type            String   // unclear-requirement, blocker-bug, scope-creep, access-issue
  status          String   @default("open") // open, in-progress, resolved
  title           String
  description     String
  attachments     String[]
  createdAt       DateTime @default(now())
  acknowledgedAt  DateTime?
  resolvedAt      DateTime?
  resolution      String?

  @@index([bountyId])
  @@index([contributorId])
  @@index([status])
  @@index([createdAt])
}

model SupportMetrics {
  id            String   @id @default(cuid())
  ticketType    String   // ticket type
  frequency     Int      @default(0) // number of times this issue type appears
  avgResolution Int      @default(0) // average resolution time in hours
  lastUpdated   DateTime @default(now()) @updatedAt

  @@unique([ticketType])
}

// ── Bounty Analytics Models ────────────────────────────────────────────────

/// Tracks each application submitted to a bounty
model BountyApplication {
  id            String    @id @default(cuid())
  bountyId      String
  bountyTitle   String
  applicantId   String    // public key / contributor identifier
  rewardUsd     Float
  difficulty    String    // beginner | intermediate | advanced | expert
  bountyType    String
  status        String    @default("pending") // pending | accepted | rejected | withdrawn
  appliedAt     DateTime  @default(now())
  acceptedAt    DateTime?
  completedAt   DateTime?
  rejectedAt    DateTime?

  @@index([bountyId])
  @@index([applicantId])
  @@index([status])
  @@index([appliedAt])
}

/// Records completed bounty payouts
model BountyCompletion {
  id            String   @id @default(cuid())
  bountyId      String
  bountyTitle   String
  contributorId String   // public key / contributor identifier
  rewardUsd     Float
  difficulty    String
  bountyType    String
  startedAt     DateTime // when work began (application accepted)
  completedAt   DateTime @default(now())
  hoursToComplete Float? // calculated: completedAt - startedAt in hours

  @@index([contributorId])
  @@index([bountyId])
  @@index([completedAt])
}

/// Hourly analytics snapshot for trend analysis
model AnalyticsSnapshot {
  id                  String   @id @default(cuid())
  snapshotAt          DateTime @default(now())

  // Core metrics
  bountiesOpen        Int      @default(0)
  bountiesCompleted   Int      @default(0)
  bountiesCancelled   Int      @default(0)
  applicationsPending Int      @default(0)
  applicationsTotal   Int      @default(0)

  // Velocity
  avgTimeToCompleteHours Float? // avg hours from start to completion
  completionRate      Float?   // completions / total closed in period
  costPerTask         Float?   // total payouts / total completions

  // Cumulative totals at snapshot time
  totalBountiesEver       Int    @default(0)
  totalCompletionsEver    Int    @default(0)
  totalPayoutsUsd         Float  @default(0)
  uniqueContributorsEver  Int    @default(0)

  @@index([snapshotAt])
}

// ── Budget Funding Models ──────────────────────────────────────────────────

/// Quarterly budget allocation for a project (backend / frontend / contracts)
model ProjectBudget {
  id        String   @id @default(cuid())
  projectId String   // logical project identifier e.g. "backend", "frontend", "contracts"
  period    String   // e.g. "2026-Q1" — year + quarter
  amount    Float    // total allocated budget in USD
  spent     Float    @default(0) // cumulative spend drawn by bounties
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  overrides BudgetOverride[]
  alerts    BudgetAlert[]

  @@unique([projectId, period])
  @@index([projectId])
  @@index([period])
}

/// Approved override allowing spend beyond the hard cap (max +20% above amount)
model BudgetOverride {
  id             String        @id @default(cuid())
  budgetId       String
  approvedBy     String        // maintainer / admin identifier
  amountApproved Float         // additional USD approved above the base amount
  reason         String        // documented justification for the override
  bountyId       String?       // optional link to the triggering bounty
  createdAt      DateTime      @default(now())

  budget ProjectBudget @relation(fields: [budgetId], references: [id])

  @@index([budgetId])
}

/// Alert events recorded when budget crosses utilisation thresholds
model BudgetAlert {
  id         String   @id @default(cuid())
  budgetId   String
  alertType  String   // "warning" (80%) | "freeze" (100%)
  utilization Float   // utilisation ratio at time of alert (0–1+)
  message    String
  notified   Boolean  @default(false) // whether maintainers have been emailed
  createdAt  DateTime @default(now())

  budget ProjectBudget @relation(fields: [budgetId], references: [id])

  @@index([budgetId])
  @@index([alertType])
  @@index([createdAt])
}
